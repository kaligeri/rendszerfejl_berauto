  "components": {
    "schemas": {
      "Car": {
        "required": [
          "brand",
          "dailyRate",
          "licensePlate"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "brand": {
            "minLength": 1,
            "type": "string"
          },
          "licensePlate": {
            "minLength": 1,
            "type": "string"
          },
          "fuelType": {
            "type": "string",
            "nullable": true
          },
          "transmission": {
            "type": "string",
            "nullable": true
          },
          "passengerCapacity": {
            "type": "integer",
            "format": "int32"
          },
          "mileage": {
            "type": "integer",
            "format": "int32"
          },
          "dailyRate": {
            "type": "number",
            "format": "double"
          },
          "isAvailable": {
            "type": "boolean"
          },
          "imageUrl": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
